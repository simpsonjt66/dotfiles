configuration {
    modi: "drun,run,filebrowser,window";
    terminal: "kitty";
    drun-display-format: "{icon} {name}";
    location: 0;
    disable-history: false;
    hide-scrollbar: true;
    display-drun: "’Ćé";
    display-run: "’Ćé";
    display-window: "’Ćé";
    display-filebrowser: "’Ćé";
    display-Network: "’Ćé";
    display-dmenu: "’Ćé";
    
    // Enable icons
    show-icons: true;
    icon-theme: "Yaru-blue";
}

